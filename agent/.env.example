# ─── LiveKit Cloud ───────────────────────────────────────────
# Get from: https://cloud.livekit.io → Project Settings → Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ─── Deepgram (STT + TTS) ───────────────────────────────────
# Get from: https://console.deepgram.com → API Keys
DEEPGRAM_API_KEY=your_deepgram_api_key

# ─── Groq (LLM — optional, alternative to Gemini) ───────────
# Get from: https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key

# ─── Google Gemini (LLM — default) ──────────────────────────
# Get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key

# ─── TTS Mode ───────────────────────────────────────────────
# "deepgram" (default) — Server-side Deepgram Aura TTS (aura-asteria-en)
# "browser"            — Fallback: Frontend SpeechSynthesis, no server audio
TTS_MODE=deepgram
